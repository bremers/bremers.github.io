@inproceedings{bremers2022how,
author = {Bremers, Alexandra},
title = {How can a robot help people draw?},
year = {2022},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
abstract = {Advances in big data, artificial intelligence (AI), augmented reality (AR), and user interface development have led to some practical digital tools and virtual interactions. However, physical interactions offer a richness that cannot be fully replaced through completely virtual interactions. I study how our data-driven tools and virtual interfaces can augment physical interactions through empirical research and building exploratory systems. For my thesis research, I focus on the activity of drawing: a task that is universally relatable, versatile, and that requires complex perception, conceptualization and motor skills. My initial studies show that the computers are social actors (CASA) paradigm also applies to drawing robots, adding a new dimension to the interaction.},
booktitle = {Companion Publication of the 2021 ACM Designing Interactive Systems Conference},
numpages = {4},
keywords = {drawing, human-robot interaction, human-machine interface, augmented reality, artificial intelligence},
location = {Virtual Event},
series = {DIS '22 Companion}
}

