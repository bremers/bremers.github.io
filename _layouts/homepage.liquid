---
layout: default
---

<!-- Hero Section -->
<div class="homepage-hero">
  <div class="hero-content">
    <h1 class="hero-name">Alexandra W.D. <span class="hero-bold">Bremers</span>, Ph.D.</h1>
    <p class="hero-tagline">I build AI-powered tools that help people make things in the real world.</p>
    <p class="hero-sub">Researcher, designer, and technologist bridging human-computer interaction, robotics, and creative systems. PhD from Cornell. 8+ years across industry R&D and academia.</p>
    <div class="hero-links">
      <a href="{{ '/cv/Bremers_cv.pdf' | relative_url }}" class="hero-link">CV</a>
      <a href="{{ '/cv/Bremers_resume.pdf' | relative_url }}" class="hero-link">Resume</a>
      <a href="https://scholar.google.com/citations?user=WB5PtlIAAAAJ&hl=en" class="hero-link">Google Scholar</a>
      <a href="https://www.linkedin.com/in/awdb" class="hero-link">LinkedIn</a>
      <a href="{{ '/cv/Bremers_portfolio2025.pdf' | relative_url }}" class="hero-link">Portfolio</a>
    </div>
  </div>
</div>

<!-- About Section -->
<div class="homepage-about">
  <div class="about-grid">
    <div class="about-photo">
      {% include figure.liquid loading="eager" path="assets/img/bdx1.png" class="img-fluid rounded" alt="Alexandra Bremers" %}
    </div>
    <div class="about-text">
      <h2>About</h2>
      {{ content }}
    </div>
  </div>
</div>

<!-- Experience Strip -->
<div class="homepage-experience">
  <h2>Experience</h2>
  <div class="exp-strip">
    <div class="exp-item">
      <span class="exp-logo">Cornell</span>
      <span class="exp-role">Ph.D. Graduate</span>
      <span class="exp-year">2020–2026</span>
    </div>
    <div class="exp-item">
      <span class="exp-logo">Disney</span>
      <span class="exp-role">R&D Intern, Walt Disney Imagineering</span>
      <span class="exp-year">2025</span>
    </div>
    <div class="exp-item">
      <span class="exp-logo">Accenture</span>
      <span class="exp-role">Research Intern, Accenture Labs</span>
      <span class="exp-year">2023</span>
    </div>
    <div class="exp-item">
      <span class="exp-logo">Toyota</span>
      <span class="exp-role">Research Intern, Toyota Research Institute</span>
      <span class="exp-year">2021</span>
    </div>
    <div class="exp-item">
      <span class="exp-logo">JLR</span>
      <span class="exp-role">HMI Researcher, Jaguar Land Rover</span>
      <span class="exp-year">2017–2020</span>
    </div>
  </div>
</div>

<!-- Featured Projects -->
<div class="homepage-featured">
  <div class="section-header">
    <h2>Featured Work</h2>
    <a href="{{ '/projects/' | relative_url }}" class="see-all">View all projects &rarr;</a>
  </div>

  {% assign featured = site.projects | where: "featured", true | sort: "importance" %}
  {% for project in featured limit: 4 %}
  <div class="featured-project {% cycle 'left', 'right' %}">
    <div class="featured-img">
      <a href="{{ project.url | relative_url }}">
        {% include figure.liquid loading="eager" path=project.img sizes="(min-width: 768px) 50vw, 95vw" alt=project.title class="img-fluid rounded" %}
      </a>
    </div>
    <div class="featured-info">
      <div class="featured-meta">
        {% if project.category %}<span class="featured-theme">{{ project.category }}</span>{% endif %}
        {% if project.year %}<span class="featured-year">{{ project.year }}</span>{% endif %}
      </div>
      <h3><a href="{{ project.url | relative_url }}">{{ project.title }}</a></h3>
      <p class="featured-desc">{{ project.description }}</p>
      {% if project.tags %}
      <div class="featured-tags">
        {% for tag in project.tags %}
        <span class="method-tag">{{ tag }}</span>
        {% endfor %}
      </div>
      {% endif %}
      {% if project.venue %}<p class="featured-venue">{{ project.venue }}</p>{% endif %}
    </div>
  </div>
  {% endfor %}
</div>

<!-- Research Themes -->
<div class="homepage-themes">
  <h2>Research Themes</h2>
  <div class="themes-grid">
    <a href="{{ '/projects/' | relative_url }}#Creative+Machines" class="theme-card">
      <h3>Creative Machines</h3>
      <p>Mixed-initiative AI systems that collaborate with people on creative tasks like drawing, fabrication, and design.</p>
    </a>
    <a href="{{ '/projects/' | relative_url }}#Sensing+%26+HRI" class="theme-card">
      <h3>Sensing & HRI</h3>
      <p>Detecting human intent and recognizing errors through social cues, facial expressions, and multimodal sensing.</p>
    </a>
    <a href="{{ '/projects/' | relative_url }}#Automotive" class="theme-card">
      <h3>Automotive HMI</h3>
      <p>In-vehicle interfaces, driver workload modeling, AR head-up displays, and mixed-reality driving simulation.</p>
    </a>
    <a href="{{ '/projects/' | relative_url }}#AI+%26+Task+Guidance" class="theme-card">
      <h3>AI & Task Guidance</h3>
      <p>Situated conversational agents and audio interfaces that guide people through physical assembly tasks.</p>
    </a>
    <a href="{{ '/projects/' | relative_url }}#Design" class="theme-card">
      <h3>Physical & Speculative Design</h3>
      <p>Tangible prototypes, speculative objects, and installations that explore the intersection of technology and experience.</p>
    </a>
  </div>
</div>

